# Document Management Service - Environment Variables
# Copy this file to .env and update with your settings

# FastAPI Settings
APP_NAME=Document Management Service
APP_VERSION=1.0.0
DEBUG=False

# Database Configuration
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/document_management

# File Storage Settings
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Allowed file formats (comma-separated)
ALLOWED_FORMATS=pdf,docx,png,txt

# Logging Settings
LOG_DIR=./logs
LOG_LEVEL=INFO

# Authentication
# Shared secret used for frontend session JWT signing/verification and backend JWT validation.
# MUST be set in non-dev environments.
AUTH_SECRET=
AUTH_COOKIE_NAME=taqim_session
AUTH_REQUIRED=True
# Comma-separated property IDs the client role is allowed to access.
# Example: PROP-001,PROP-002
CLIENT_ALLOWED_PROPERTY_IDS=

# Celery / Redis Settings
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
ANALYSIS_MODULE_TIMEOUT_SECONDS=90

# Performance / runtime safety
VECTOR_INDEX_MAX_LOADED_INDICES=64
VECTOR_SEARCH_PREFILTER_MIN_DOCS=16
VECTOR_SEARCH_PREFILTER_MULTIPLIER=4
VECTOR_SEARCH_PREFILTER_MIN_CANDIDATES=20
SKIP_DEPENDENCY_CHECK=False

# OpenAI Analysis Settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
# Optional: set only if using a custom OpenAI-compatible endpoint
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=120
