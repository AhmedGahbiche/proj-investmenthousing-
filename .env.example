# Document Management Service - Environment Variables
# Copy this file to .env and update with your settings

# FastAPI Settings
APP_NAME=Document Management Service
APP_VERSION=1.0.0
DEBUG=False

# Database Configuration
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/document_management

# File Storage Settings
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Allowed file formats (comma-separated)
ALLOWED_FORMATS=pdf,docx,png,txt

# Logging Settings
LOG_DIR=./logs
LOG_LEVEL=INFO

# Celery / Redis Settings
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# OpenAI Analysis Settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
# Optional: set only if using a custom OpenAI-compatible endpoint
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=120
