# Frontend authentication settings
# Must match backend AUTH_SECRET
AUTH_SECRET=replace-with-a-strong-random-secret
AUTH_COOKIE_NAME=taqim_session

# Login credentials (server-side only, used by Next.js API route)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password
CLIENT_EMAIL=client@example.com
CLIENT_PASSWORD=change-me-client-password

# Backend API URL consumed by client-side pages
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
